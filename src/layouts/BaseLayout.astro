---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../lib/paths';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Biblioteca curada de prompts para consultores.' } = Astro.props;
const fullTitle = title === 'PromptHub' ? title : `${title} · PromptHub`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <SiteHeader />
    <main id="contenido" class="flex-1 w-full mx-auto max-w-6xl px-4 sm:px-6 py-6 sm:py-10">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
