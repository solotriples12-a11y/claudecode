---
import LevelBadge from './LevelBadge.astro';
import TypeBadge from './TypeBadge.astro';
import { url } from '../lib/paths';

interface Props {
  slug: string;
  title: string;
  shortName: string;
  summary: string;
  level: string;
  tags?: string[];
}

const { slug, title, shortName, summary, level, tags = [] } = Astro.props;
---

<article class="group rounded-xl border border-ink-200 bg-white p-5 hover:border-ink-300 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-150">
  <div class="flex flex-wrap items-center gap-2 mb-2.5">
    <TypeBadge type="technique" />
    <LevelBadge level={level} />
  </div>
  <h3 class="text-[15px] font-bold leading-snug mb-1 tracking-tight">
    <a
      href={url(`tecnicas/${slug}/`)}
      class="text-ink-900 no-underline group-hover:underline underline-offset-2"
    >
      {shortName}
    </a>
  </h3>
  <p class="text-xs text-ink-400 mb-2 italic">{title}</p>
  <p class="text-[13px] text-ink-600 leading-relaxed">{summary}</p>
  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5" aria-label="Etiquetas">
        {tags.slice(0, 5).map((t) => (
          <li class="text-[10.5px] text-ink-400 bg-ink-100 border border-ink-200 px-2 py-0.5 rounded-full">{t}</li>
        ))}
      </ul>
    )
  }
</article>
