---
import LevelBadge from './LevelBadge.astro';
import TypeBadge from './TypeBadge.astro';
import { url } from '../lib/paths';

interface Props {
  slug: string;
  title: string;
  shortName: string;
  summary: string;
  level: string;
  tags?: string[];
}

const { slug, title, shortName, summary, level, tags = [] } = Astro.props;
---

<article class="group rounded border border-ink-200 bg-white p-4 hover:border-ink-400 transition-colors">
  <div class="flex flex-wrap items-center gap-2 mb-2">
    <TypeBadge type="technique" />
    <LevelBadge level={level} />
  </div>
  <h3 class="text-lg font-semibold leading-snug mb-1">
    <a
      href={url(`tecnicas/${slug}/`)}
      class="text-ink-900 no-underline group-hover:underline underline-offset-2"
    >
      {shortName}
    </a>
  </h3>
  <p class="text-xs text-ink-500 mb-1.5">{title}</p>
  <p class="text-sm text-ink-600 leading-relaxed">{summary}</p>
  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5 text-xs text-ink-500" aria-label="Etiquetas">
        {tags.slice(0, 5).map((t) => (
          <li>#{t}</li>
        ))}
      </ul>
    )
  }
</article>
