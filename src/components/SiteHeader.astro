---
import { url } from '../lib/paths';

const home = url();
const categorias = url('categorias/');
const tecnicas = url('tecnicas/');
const currentPath = Astro.url.pathname;
const isHome = currentPath === home || currentPath === home.replace(/\/$/, '');
const isCategorias = currentPath.startsWith(categorias.replace(/\/$/, ''));
const isTecnicas = currentPath.startsWith(tecnicas.replace(/\/$/, ''));
---

<header class="bg-ink-100 border-b border-ink-200">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex items-baseline gap-2.5 pt-4 sm:pt-5">
      <a
        href={home}
        class="text-[1.1rem] font-extrabold tracking-tight text-ink-900 no-underline hover:text-ink-900 leading-none"
        aria-label="PromptHub, ir al inicio"
      >
        PromptHub
      </a>
      <span class="hidden sm:inline text-sm text-ink-400 leading-none">
        Prompts y técnicas para consultores
      </span>
    </div>
    <nav aria-label="Principal" class="flex gap-0 mt-3">
      {[
        { href: home, label: 'Inicio', active: isHome },
        { href: categorias, label: 'Categorías', active: isCategorias },
        { href: tecnicas, label: 'Técnicas', active: isTecnicas },
      ].map(({ href, label, active }) => (
        <a
          href={href}
          class:list={[
            'px-3.5 py-2 text-sm font-medium no-underline border-b-2 -mb-px transition-colors',
            active
              ? 'text-accent border-accent'
              : 'text-ink-600 border-transparent hover:text-ink-900 hover:border-ink-300',
          ]}
          aria-current={active ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
