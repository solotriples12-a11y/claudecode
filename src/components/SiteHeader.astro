---
import { url } from '../lib/paths';

const home = url();
const categorias = url('categorias/');
const tecnicas = url('tecnicas/');
const currentPath = Astro.url.pathname;
const isHome = currentPath === home || currentPath === home.replace(/\/$/, '');
const isCategorias = currentPath.startsWith(categorias.replace(/\/$/, ''));
const isTecnicas = currentPath.startsWith(tecnicas.replace(/\/$/, ''));
---

<header class="border-b border-ink-200 bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
    <a
      href={home}
      class="flex items-center gap-2 no-underline text-ink-900 hover:text-ink-900"
      aria-label="PromptHub, ir al inicio"
    >
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded bg-accent text-white font-bold"
        aria-hidden="true"
      >
        Ph
      </span>
      <span class="font-semibold tracking-tight text-lg">PromptHub</span>
    </a>
    <nav aria-label="Principal" class="flex items-center gap-1 sm:gap-3 text-sm">
      <a
        href={home}
        class:list={[
          'px-2 py-1 rounded no-underline',
          isHome ? 'text-ink-900 font-medium' : 'text-ink-600 hover:text-ink-900',
        ]}
        aria-current={isHome ? 'page' : undefined}
      >
        Inicio
      </a>
      <a
        href={categorias}
        class:list={[
          'px-2 py-1 rounded no-underline',
          isCategorias ? 'text-ink-900 font-medium' : 'text-ink-600 hover:text-ink-900',
        ]}
        aria-current={isCategorias ? 'page' : undefined}
      >
        Categorías
      </a>
      <a
        href={tecnicas}
        class:list={[
          'px-2 py-1 rounded no-underline',
          isTecnicas ? 'text-ink-900 font-medium' : 'text-ink-600 hover:text-ink-900',
        ]}
        aria-current={isTecnicas ? 'page' : undefined}
      >
        Técnicas
      </a>
    </nav>
  </div>
</header>
