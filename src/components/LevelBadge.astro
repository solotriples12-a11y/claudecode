---
import { LEVEL_LABELS, type Level } from '../lib/categories';

interface Props {
  level: Level | string;
}

const { level } = Astro.props;
const label = LEVEL_LABELS[level as Level] ?? level;

const colorByLevel: Record<string, string> = {
  basico: 'border-emerald-200 bg-emerald-50 text-emerald-700',
  intermedio: 'border-blue-200 bg-blue-50 text-blue-700',
  avanzado: 'border-violet-200 bg-violet-50 text-violet-700',
};
const classes = colorByLevel[level] ?? 'border-ink-200 bg-ink-50 text-ink-700';
---

<span class:list={['inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium', classes]}>
  {label}
</span>
