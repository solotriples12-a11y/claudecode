---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LevelBadge from '../../components/LevelBadge.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';
import { url } from '../../lib/paths';

export async function getStaticPaths() {
  const techniques = await getCollection('techniques');
  return techniques.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry('techniques', slug as string);
if (!entry) throw new Error(`Técnica no encontrada: ${slug}`);

const { data } = entry;
const { Content } = await entry.render();
const hasBody = (entry.body ?? '').trim().length > 0;

const reviewedAtFmt = new Intl.DateTimeFormat('es-ES', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(data.reviewedAt);

const allTechniques = await getCollection('techniques');
const related = data.relatedTechniques
  .map((slug) => allTechniques.find((t) => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => !!t);
---

<BaseLayout title={data.shortName} description={data.summary}>
  <nav class="mb-4 text-sm" aria-label="Migas de pan">
    <a href={url()} class="text-ink-600 hover:text-ink-900">Inicio</a>
    <span class="text-ink-400 mx-1.5" aria-hidden="true">/</span>
    <a href={url('tecnicas/')} class="text-ink-600 hover:text-ink-900">Técnicas</a>
    <span class="text-ink-400 mx-1.5" aria-hidden="true">/</span>
    <span class="text-ink-800">{data.shortName}</span>
  </nav>

  <header class="mb-6">
    <div class="flex flex-wrap items-center gap-2 mb-2">
      <TypeBadge type="technique" />
      <LevelBadge level={data.level} />
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-ink-900 leading-tight mb-2">{data.title}</h1>
    <p class="text-ink-600 max-w-prose leading-relaxed">{data.summary}</p>
  </header>

  <div class="grid gap-6 lg:grid-cols-[1fr_280px]">
    <!-- Contenido principal -->
    <div class="order-last lg:order-first min-w-0 space-y-8">
      <section aria-labelledby="example-title">
        <h2 id="example-title" class="text-sm font-semibold uppercase tracking-wider text-ink-500 mb-3">
          Ejemplo: antes / después
        </h2>
        <BeforeAfter
          without={data.example.without}
          with={data.example.with}
          observation={data.example.observation}
        />
      </section>

      <section aria-labelledby="when-title" class="grid gap-4 sm:grid-cols-2">
        <div class="rounded border border-emerald-200 bg-emerald-50/50 p-4">
          <h2 id="when-title" class="text-sm font-semibold text-emerald-900 mb-2 flex items-center gap-1.5">
            <span aria-hidden="true">✓</span> Cuándo usarla
          </h2>
          <ul class="space-y-1.5 text-sm text-ink-800 list-disc pl-5">
            {data.whenToUse.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        <div class="rounded border border-rose-200 bg-rose-50/50 p-4">
          <h2 class="text-sm font-semibold text-rose-900 mb-2 flex items-center gap-1.5">
            <span aria-hidden="true">✗</span> Cuándo NO usarla
          </h2>
          <ul class="space-y-1.5 text-sm text-ink-800 list-disc pl-5">
            {data.whenNotToUse.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </section>

      <section aria-labelledby="howto-title">
        <h2 id="howto-title" class="text-sm font-semibold uppercase tracking-wider text-ink-500 mb-2">
          Cómo aplicarla
        </h2>
        <ol class="space-y-2 text-ink-800 list-decimal pl-5 leading-relaxed">
          {data.howTo.map((s) => <li>{s}</li>)}
        </ol>
      </section>

      {
        data.pitfalls.length > 0 && (
          <section aria-labelledby="pitfalls-title">
            <h2 id="pitfalls-title" class="text-sm font-semibold uppercase tracking-wider text-ink-500 mb-2">
              Errores comunes
            </h2>
            <ul class="space-y-1.5 text-ink-800 list-disc pl-5 leading-relaxed">
              {data.pitfalls.map((p) => <li>{p}</li>)}
            </ul>
          </section>
        )
      }

      {
        hasBody && (
          <section aria-labelledby="notes-title">
            <h2 id="notes-title" class="text-sm font-semibold uppercase tracking-wider text-ink-500 mb-2">
              Notas
            </h2>
            <div class="prose-prompt max-w-none text-ink-800 leading-relaxed">
              <Content />
            </div>
          </section>
        )
      }
    </div>

    <!-- Sidebar: metadatos + relacionadas -->
    <aside class="order-first lg:order-last" aria-label="Metadatos y técnicas relacionadas">
      <div class="lg:sticky lg:top-4 flex flex-col gap-4">
        {
          related.length > 0 && (
            <section class="rounded border border-ink-200 bg-white p-4">
              <h2 class="text-xs font-semibold uppercase tracking-wider text-ink-500 mb-2">
                Técnicas relacionadas
              </h2>
              <ul class="space-y-1.5 text-sm">
                {related.map((r) => (
                  <li>
                    <a
                      href={url(`tecnicas/${r.slug}/`)}
                      class="text-accent hover:underline underline-offset-2"
                    >
                      {r.data.shortName}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <section class="rounded border border-ink-200 bg-white p-4 text-sm">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-ink-500 mb-2">
            Metadatos
          </h2>
          <dl class="space-y-2">
            <div class="flex gap-2">
              <dt class="text-ink-500 min-w-[5rem]">Autor:</dt>
              <dd class="text-ink-800">{data.author}</dd>
            </div>
            <div class="flex gap-2">
              <dt class="text-ink-500 min-w-[5rem]">Revisado:</dt>
              <dd class="text-ink-800">{reviewedAtFmt}</dd>
            </div>
            <div class="flex gap-2">
              <dt class="text-ink-500 min-w-[5rem]">Nivel:</dt>
              <dd class="text-ink-800">{data.level}</dd>
            </div>
          </dl>
          {
            data.tags.length > 0 && (
              <ul class="mt-3 flex flex-wrap gap-1.5 text-xs text-ink-600" aria-label="Etiquetas">
                {data.tags.map((t) => (
                  <li class="rounded bg-ink-100 px-1.5 py-0.5">#{t}</li>
                ))}
              </ul>
            )
          }
        </section>

        {
          data.references.length > 0 && (
            <section class="rounded border border-ink-200 bg-white p-4 text-sm">
              <h2 class="text-xs font-semibold uppercase tracking-wider text-ink-500 mb-2">
                Referencias
              </h2>
              <ul class="space-y-1.5">
                {data.references.map((r) => (
                  <li>
                    <a
                      href={r.url}
                      class="text-accent hover:underline underline-offset-2"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {r.title} ↗
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </div>
    </aside>
  </div>
</BaseLayout>
