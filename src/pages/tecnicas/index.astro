---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechniqueCard from '../../components/TechniqueCard.astro';
import { LEVELS, LEVEL_LABELS, type Level } from '../../lib/categories';

const techniques = await getCollection('techniques');

const byLevel = new Map<Level, typeof techniques>();
for (const l of LEVELS) byLevel.set(l, []);
for (const t of techniques) {
  byLevel.get(t.data.level as Level)!.push(t);
}
for (const [l, list] of byLevel) {
  list.sort((a, b) => a.data.order - b.data.order);
  byLevel.set(l, list);
}

const levelIntro: Record<Level, string> = {
  basico: 'Empieza por aquí: la base que cualquier consultor debe dominar para que sus prompts funcionen de forma consistente.',
  intermedio: 'Técnicas para cuando la tarea tiene varios pasos, requiere razonamiento o debes consolidar calidad antes de entregar.',
  avanzado: 'Herramientas para problemas con alta incertidumbre, decisiones complejas o cuando quieres exprimir al modelo más allá del uso cotidiano.',
};

const dividerColor: Record<Level, string> = {
  basico: '#a7f3d0',
  intermedio: '#bfdbfe',
  avanzado: '#c4b5fd',
};

const titleColor: Record<Level, string> = {
  basico: '#059669',
  intermedio: '#2563eb',
  avanzado: '#7c3aed',
};
---

<BaseLayout title="Técnicas de prompting" description="Técnicas de prompting curadas para consultores: qué son, cuándo usarlas y ejemplos antes/después.">
  <header class="mb-10">
    <div class="text-[10.5px] font-bold uppercase tracking-widest text-ink-400 mb-2">Manual de técnicas</div>
    <h1 class="text-[2rem] font-extrabold text-ink-900 tracking-tight mb-3">Técnicas de prompting</h1>
    <p class="text-base text-ink-600 max-w-2xl leading-[1.7]">
      Más allá de copiar prompts, entender estas técnicas te permite adaptar
      cualquier prompt a tu caso y diagnosticar por qué una salida no funciona.
      Cada ficha incluye cuándo usarla, cómo aplicarla y un ejemplo antes/después.
    </p>
  </header>

  {
    LEVELS.map((level) => {
      const items = byLevel.get(level) ?? [];
      if (items.length === 0) return null;
      return (
        <section aria-labelledby={`level-${level}`} class="mb-14">
          <div class="flex items-center gap-4 mb-3">
            <h2
              id={`level-${level}`}
              class="text-2xl font-bold tracking-tight whitespace-nowrap"
              style={`color: ${titleColor[level]}`}
            >
              {LEVEL_LABELS[level]}
            </h2>
            <div
              class="h-0.5 flex-1 rounded"
              style={`background: linear-gradient(to right, ${dividerColor[level]}, transparent)`}
            />
          </div>
          <p class="text-sm text-ink-600 mb-5 max-w-prose">{levelIntro[level]}</p>
          <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((t) => (
              <li>
                <TechniqueCard
                  slug={t.slug}
                  title={t.data.title}
                  shortName={t.data.shortName}
                  summary={t.data.summary}
                  level={t.data.level}
                  tags={t.data.tags}
                />
              </li>
            ))}
          </ul>
        </section>
      );
    })
  }
</BaseLayout>
