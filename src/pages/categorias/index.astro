---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES } from '../../lib/categories';
import { url } from '../../lib/paths';

const prompts = await getCollection('prompts');
const countBySlug = new Map<string, number>();
for (const p of prompts) {
  countBySlug.set(p.data.category, (countBySlug.get(p.data.category) ?? 0) + 1);
}
---

<BaseLayout title="Categorías">
  <header class="mb-6">
    <h1 class="text-3xl font-bold text-ink-900 mb-2">Categorías</h1>
    <p class="text-ink-600 max-w-prose">
      Explora los prompts agrupados por tipo de tarea.
    </p>
  </header>

  <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      CATEGORIES.map((c) => {
        const count = countBySlug.get(c.slug) ?? 0;
        return (
          <li>
            <a
              href={url(`categorias/${c.slug}/`)}
              class="block rounded border border-ink-200 bg-white p-4 no-underline hover:border-ink-400 transition-colors"
            >
              <div class="flex items-start justify-between gap-3 mb-1">
                <h2 class="text-lg font-semibold text-ink-900">{c.label}</h2>
                <span class="shrink-0 text-xs font-medium text-ink-500">
                  {count} {count === 1 ? 'prompt' : 'prompts'}
                </span>
              </div>
              <p class="text-sm text-ink-600 leading-relaxed">{c.description}</p>
            </a>
          </li>
        );
      })
    }
  </ul>
</BaseLayout>
