---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LevelBadge from '../../components/LevelBadge.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import CopyButton from '../../components/CopyButton.astro';
import ReviewChecklist from '../../components/ReviewChecklist.astro';
import { getCategoryLabel } from '../../lib/categories';
import { url } from '../../lib/paths';

export async function getStaticPaths() {
  const prompts = await getCollection('prompts');
  return prompts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry('prompts', slug as string);
if (!entry) throw new Error(`Prompt no encontrado: ${slug}`);

const { data, body } = entry;
const { Content } = await entry.render();

const categoryLabel = getCategoryLabel(data.category);
const reviewedAtFmt = new Intl.DateTimeFormat('es-ES', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(data.reviewedAt);

const copyText = body.trim();
---

<BaseLayout title={data.title} description={data.summary}>
  <nav class="mb-5 flex items-center gap-1.5 text-[12.5px] text-ink-400" aria-label="Migas de pan">
    <a href={url()} class="hover:text-accent transition-colors no-underline">Inicio</a>
    <span aria-hidden="true">/</span>
    <a href={url(`categorias/${data.category}/`)} class="hover:text-accent transition-colors no-underline">{categoryLabel}</a>
    <span aria-hidden="true">/</span>
    <span class="text-ink-700 font-semibold">{data.title}</span>
  </nav>

  <header class="mb-10">
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <TypeBadge type="prompt" />
      <LevelBadge level={data.level} />
    </div>
    <h1 class="text-[2rem] sm:text-[2.1rem] font-extrabold text-ink-900 leading-[1.12] tracking-tight mb-3">{data.title}</h1>
    <p class="text-base text-ink-600 max-w-2xl leading-[1.7]">{data.summary}</p>
    {data.useCase && (
      <p class="mt-2 text-sm text-ink-400">
        <strong class="text-ink-700 font-semibold">Caso de uso:</strong> {data.useCase}
      </p>
    )}
  </header>

  <div class="grid gap-8 lg:grid-cols-[1fr_292px]">
    <!-- Sidebar: botón copiar + checklist (arriba en mobile, derecha en desktop) -->
    <aside class="order-first lg:order-last" aria-label="Acciones del prompt">
      <div class="lg:sticky lg:top-4 flex flex-col gap-4">
        <CopyButton text={copyText} slug={entry.slug} />
        <ReviewChecklist items={data.reviewChecklist} id={`checklist-${entry.slug}`} />
      </div>
    </aside>

    <!-- Contenido principal -->
    <div class="order-last lg:order-first min-w-0 space-y-8">

      <!-- Para qué sirve / no sirve -->
      <section aria-labelledby="suitable-title" class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl border-[1.5px] border-emerald-200 bg-[#f0fdf9] p-5">
          <div class="flex items-center gap-2 mb-3">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            <h2 id="suitable-title" class="text-sm font-bold text-emerald-700">Para qué sirve</h2>
          </div>
          <ul class="space-y-2 text-sm text-emerald-900 list-disc pl-5 leading-relaxed">
            {data.suitableFor.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        <div class="rounded-xl border-[1.5px] border-red-200 bg-[#fff5f5] p-5">
          <div class="flex items-center gap-2 mb-3">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
            <h2 class="text-sm font-bold text-red-700">Para qué NO sirve</h2>
          </div>
          <ul class="space-y-2 text-sm text-red-900 list-disc pl-5 leading-relaxed">
            {data.notSuitableFor.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </section>

      <!-- Texto del prompt -->
      <section aria-labelledby="prompt-title">
        <div class="text-[10.5px] font-bold uppercase tracking-widest text-ink-400 mb-3">
          Texto del prompt
        </div>
        <div class="rounded-xl bg-[#181d2e] p-6 shadow-inner">
          <div class="prose-prompt max-w-none text-[13px] leading-[1.8] text-[#c8cde0] font-mono whitespace-pre-wrap break-words">
            <Content />
          </div>
        </div>
      </section>

      <!-- Ejemplos -->
      <section aria-labelledby="example-input-title">
        <div class="text-[10.5px] font-bold uppercase tracking-widest text-ink-400 mb-3">
          Ejemplo de input
        </div>
        <pre class="rounded-xl border border-ink-200 bg-white p-5 text-[12.5px] overflow-x-auto whitespace-pre-wrap break-words leading-relaxed font-mono text-ink-600">{data.exampleInput}</pre>
      </section>

      <section aria-labelledby="example-output-title">
        <div class="text-[10.5px] font-bold uppercase tracking-widest text-ink-400 mb-3">
          Ejemplo de output
        </div>
        <pre class="rounded-xl border border-ink-200 bg-white p-5 text-[12.5px] overflow-x-auto whitespace-pre-wrap break-words leading-[1.85] font-mono text-ink-700">{data.exampleOutput}</pre>
      </section>

      <!-- Metadatos -->
      <section aria-labelledby="meta-title" class="rounded-xl border border-ink-200 bg-white p-5 text-sm">
        <div class="text-[10.5px] font-bold uppercase tracking-widest text-ink-400 mb-3">Metadatos</div>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">
          <div class="flex gap-2">
            <dt class="text-ink-400 min-w-[7rem]">Autor:</dt>
            <dd class="text-ink-800 font-semibold">{data.author}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-ink-400 min-w-[7rem]">Revisado:</dt>
            <dd class="text-ink-800 font-semibold">{reviewedAtFmt}</dd>
          </div>
          {
            data.recommendedModel && (
              <div class="flex gap-2">
                <dt class="text-ink-400 min-w-[7rem]">Modelo sugerido:</dt>
                <dd class="text-ink-800 font-semibold">{data.recommendedModel}</dd>
              </div>
            )
          }
          <div class="flex gap-2">
            <dt class="text-ink-400 min-w-[7rem]">Nivel:</dt>
            <dd class="text-ink-800 font-semibold">{data.level}</dd>
          </div>
        </dl>
        {
          data.tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-1.5" aria-label="Etiquetas">
              {data.tags.map((t) => (
                <li class="text-[11px] text-ink-400 bg-ink-100 border border-ink-200 px-2 py-0.5 rounded-full">#{t}</li>
              ))}
            </ul>
          )
        }
      </section>
    </div>
  </div>
</BaseLayout>
